# CoRoute environment template — copy to .env and fill in. NEVER commit real secrets.
# Referenced by CLAUDE.md commands and the backend config (backend/app/core/config).

# ----- App -----
APP_ENV=development                 # development | production
APP_BASE_URL=http://localhost:5173  # frontend origin (Vite dev server)
API_BASE_URL=http://localhost:8000  # FastAPI origin

# ----- Database -----
# Request-path role: RLS-SUBJECT. Must NOT have BYPASSRLS. (privacy invariant #2)
DATABASE_URL=postgresql+asyncpg://coroute_app:CHANGEME@localhost:5432/coroute

# Isolated AI-synthesis reader (BYPASSRLS) — server-side synthesis ONLY.
# Never used by request handlers. (privacy invariant #3)
DATABASE_URL_SYNTHESIS=postgresql+asyncpg://coroute_reader:CHANGEME@localhost:5432/coroute

# ----- Auth (magic-link JWT) -----
JWT_SECRET=CHANGEME-generate-a-long-random-string
JWT_EXPIRES_MINUTES=43200           # 30 days
MAGIC_LINK_TTL_MINUTES=15

# ----- LLM synthesis provider -----
# auto = anthropic if ANTHROPIC_API_KEY set, else stub. Force with: anthropic | ollama | stub
LLM_PROVIDER=auto

# Claude API. See the `claude-api` skill for current model IDs / pricing.
ANTHROPIC_API_KEY=sk-ant-CHANGEME
CLAUDE_MODEL=claude-opus-4-8        # default synthesis model
CLAUDE_MODEL_CHEAP=claude-sonnet-4-6

# Ollama (local models). Set LLM_PROVIDER=ollama to use these.
#   ollama pull phi3:mini   (then `ollama serve` is usually already running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ----- Integrations (planned, Day 3) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_MAPS_API_KEY=

# ----- Observability -----
SENTRY_DSN=
LOG_LEVEL=info
